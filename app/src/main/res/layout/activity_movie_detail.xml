<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- App title top left -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginTop="24dp"
            android:text="@string/app_name"
            android:textColor="@color/colorTextPrimary"
            android:textSize="@dimen/toolbar_title_size"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Settings icon top right -->
        <TextView
            android:id="@+id/tvSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:text="⚙️"
            android:textSize="20sp"
            android:contentDescription="@string/cd_settings_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- "🎥 Recommended Movies..." heading -->
        <TextView
            android:id="@+id/tvRecommendedHeading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:layout_marginTop="120dp"
            android:text="@string/recommended_movies"
            android:textColor="@color/colorTextPrimary"
            android:textSize="@dimen/text_headline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Mood search result label -->
        <TextView
            android:id="@+id/tvMoodLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            android:textColor="@color/colorTextPrimary"
            android:textSize="@dimen/text_subtitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvRecommendedHeading" />

        <!-- Movie card (dark container) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMovie"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMoodLabel">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/card_padding">

                <!-- Movie poster image - USING SHAPEABLE IMAGE VIEW -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivMoviePoster"
                    android:layout_width="@dimen/card_image_width"
                    android:layout_height="@dimen/card_image_height"
                    android:contentDescription="@string/cd_movie_poster"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/thesummer"
                    android:background="@color/colorSurfaceCard"
                    app:shapeAppearanceOverlay="@style/RoundedImageView"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Movie title -->
                <TextView
                    android:id="@+id/tvMovieTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivMoviePoster"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Director and year -->
                <TextView
                    android:id="@+id/tvDirectorYear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_caption"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivMoviePoster"
                    app:layout_constraintTop_toBottomOf="@id/tvMovieTitle" />

                <!-- Star rating -->
                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivMoviePoster"
                    app:layout_constraintTop_toBottomOf="@id/tvDirectorYear" />

                <!-- Movie synopsis -->
                <TextView
                    android:id="@+id/tvSynopsis"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:lineSpacingMultiplier="1.4"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ivMoviePoster" />

                <!-- Add to watchlist button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddToWatchlist"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/add_to_watchlist"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_button"
                    app:backgroundTint="@color/colorButtonPrimary"
                    app:cornerRadius="@dimen/button_corner_radius"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSynopsis" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- View more button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewMore"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_secondary_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:paddingHorizontal="24dp"
            android:text="@string/view_more"
            android:textColor="@color/colorTextPrimary"
            android:textSize="20sp"
            app:backgroundTint="@color/colorButtonSecondary"
            app:cornerRadius="@dimen/button_secondary_corner_radius"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardMovie" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>