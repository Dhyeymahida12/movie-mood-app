<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- Toolbar -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginTop="24dp"
            android:text="@string/app_name"
            android:textColor="@color/colorTextPrimary"
            android:textSize="@dimen/toolbar_title_size"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:layout_marginTop="20dp"
            android:text="⚙️"
            android:contentDescription="@string/cd_settings_icon"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Log in heading -->
        <TextView
            android:id="@+id/tvLoginHeading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="130dp"
            android:gravity="center"
            android:text="@string/login_title"
            android:textColor="@color/colorTextPrimary"
            android:textSize="@dimen/text_headline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Email label -->
        <TextView
            android:id="@+id/tvEmailLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/login_email_label"
            android:textColor="@color/colorTextSecondary"
            android:textSize="@dimen/text_caption"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLoginHeading" />

        <!-- Email input -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEmail"
            android:layout_width="0dp"
            android:layout_height="71dp"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardBackgroundColor="@color/colorSurfaceCard"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEmailLabel">

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="@string/login_email_hint"
                android:inputType="textEmailAddress"
                android:autofillHints="emailAddress"
                android:paddingHorizontal="@dimen/spacing_md"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextHint"
                android:textSize="@dimen/text_body" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Password label -->
        <TextView
            android:id="@+id/tvPasswordLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/login_password_label"
            android:textColor="@color/colorTextSecondary"
            android:textSize="@dimen/text_caption"
            app:layout_constraintTop_toBottomOf="@id/cardEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Password input -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPassword"
            android:layout_width="0dp"
            android:layout_height="71dp"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardBackgroundColor="@color/colorSurfaceCard"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="@string/login_password_hint"
                android:inputType="textPassword"
                android:autofillHints="password"
                android:paddingHorizontal="@dimen/spacing_md"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextHint"
                android:textSize="@dimen/text_body" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Confirm password label -->
        <TextView
            android:id="@+id/tvConfirmPasswordLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/login_confirm_password_label"
            android:textColor="@color/colorTextSecondary"
            android:textSize="@dimen/text_caption"
            app:layout_constraintTop_toBottomOf="@id/cardPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Confirm password input -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardConfirmPassword"
            android:layout_width="0dp"
            android:layout_height="71dp"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardBackgroundColor="@color/colorSurfaceCard"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tvConfirmPasswordLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="@string/login_password_hint"
                android:inputType="textPassword"
                android:autofillHints="password"
                android:paddingHorizontal="@dimen/spacing_md"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextHint"
                android:textSize="@dimen/text_body" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Sign up button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignUp"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/signup_btn"
            android:textColor="@color/colorTextPrimary"
            android:textSize="@dimen/text_button"
            app:backgroundTint="@color/colorButtonPrimary"
            app:cornerRadius="@dimen/button_corner_radius"
            app:layout_constraintTop_toBottomOf="@id/cardConfirmPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
